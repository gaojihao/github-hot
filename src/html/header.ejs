<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <link rel="icon" type="image/x-icon" href="https://github.githubassets.com/favicon.ico">
  <title> <%= title %> </title>
  <meta name="description" content="<%= title %>">
  <style>
    * { box-sizing: border-box; }
    html, body, ul, li, h1 { margin: 0; padding: 0; }
    ul { list-style: none; }
    html, body {
      font-size: 14px;
      font-family: -apple-system, "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Hiragino Sans GB", "WenQuanYi Micro Hei", "Microsoft Yahei", sans-serif;
      color: #1f2328;
      background: #fff;
    }
    body { text-align: center; }
    a { color: #1f2328; text-decoration: none; transition: color .15s ease; }
    a:hover { color: #0969da; }

    .title { padding: 46px 0 0 0; font-size: 24px; line-height: 32px; font-weight: 600; color: #1f2328; }
    .time { padding: 6px 0 2px 0; font-size: 12px; color: #9ba1a8; }

    .tabs { padding: 16px 12px 22px; }
    .tabs a {
      background: #f6f8fa;
      display: inline-block;
      padding: 7px 14px;
      font-size: 14px;
      color: #424a53;
      border-radius: 6px;
      border: 1px solid #d0d7de;
      line-height: 18px;
      transition: all .15s ease;
    }
    .tabs a:hover { background: #eaeef2; color: #0969da; border-color: #afb8c1; }
    .tabs a.active { background: #0969da; color: #fff; border-color: #0969da; }
    .tab-group {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin: 0 4px;
      vertical-align: middle;
      line-height: 32px;
    }
    .tab-group + .tab-group { margin-left: 12px; padding-left: 16px; border-left: 1px solid #e5e7eb; }

    .list {
      text-align: left;
      max-width: 960px;
      margin: 0 auto;
      border: 1px solid #d0d7de;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(31, 35, 40, 0.04);
      background: #fff;
    }
    .list a { color: #0969da; }
    .list a:hover { color: #0550ae; text-decoration: underline; }
    .list img { width: 36px; height: 36px; border-radius: 6px; display: block; margin: 0 auto; background-color: #f6f8fa; border: 0; }

    .list li { padding: 14px 18px; margin: 0; transition: background .15s; border-bottom: 1px solid #eaeef2; }
    .list li:last-child { border-bottom: 0; }
    .list li:hover { background: #f6f8fa; }
    .list li > div { display: table-cell; vertical-align: top; font-size: 14px; }
    .list li > div.info { width: 100%; }
    .list li div.rank { padding: 2px 10px 0 0; min-width: 28px; }
    .list li div.rank span { font-weight: 600; color: #6e7781; }

    .list li.rank-title {
      background: #0969da;
      margin: 0;
      padding: 12px 18px;
      font-size: 14px;
      font-weight: 600;
      color: #fff;
      border-bottom: 0;
    }
    .list li.rank-title:hover { background: #0969da; }
    .list li.rank-title a, .list li.rank-title span { color: #fff; }
    .list li.rank-title a:hover { color: #fff; text-decoration: underline; }

    .list li.rank-title .select { float: right; font-size: 13px; line-height: 20px; font-weight: 400; }
    .list li.rank-title .select a { color: rgba(255, 255, 255, 0.65); padding: 0 6px; }
    .list li.rank-title .select a:hover { color: #fff; text-decoration: none; }
    .list li.rank-title .select a.active { color: #ffd33d; font-weight: 600; }

    .list li.filter-bar {
      padding: 10px 18px;
      background: #f6f8fa;
      border-bottom: 1px solid #d0d7de;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .list li.filter-bar:hover { background: #f6f8fa; }
    .list .filter-input {
      flex: 1;
      border: 1px solid #d0d7de;
      border-radius: 6px;
      padding: 6px 10px;
      font-size: 13px;
      font-family: inherit;
      background: #fff;
      color: #1f2328;
      outline: none;
      transition: border-color .15s, box-shadow .15s;
    }
    .list .filter-input:focus {
      border-color: #0969da;
      box-shadow: 0 0 0 3px rgba(9, 105, 218, 0.15);
    }
    .list .filter-stat { font-size: 12px; color: #57606a; white-space: nowrap; }
    .list li.filter-empty { color: #6e7781; text-align: center; padding: 24px; font-size: 13px; }
    .list li.filter-empty:hover { background: transparent; }

    .list li div.sub-title { color: #1f2328; margin: 6px 0 4px 0; }
    .list li a.language,
    .list li span.star {
      display: inline-block;
      padding: 2px 8px;
      margin-right: 4px;
      background: #f6f8fa;
      color: #424a53;
      border-radius: 12px;
      font-size: 12px;
      line-height: 18px;
      border: 1px solid #d0d7de;
    }
    .list li a.language:hover { background: #eaeef2; color: #0969da; }

    .list li div.followers { font-size: 12px; color: #57606a; white-space: nowrap; }
    .list li div.followers a { color: #424a53; }
    .list li div.followers * { vertical-align: middle; }
    .list li div.followers svg { display: inline-block; fill: #6e7781; width: 12px; height: 12px; vertical-align: text-bottom; }

    .list li div.details { padding: 8px 0 0 0; font-size: 12px; color: #57606a; clear: both; display: block; line-height: 18px; }
    .list li div.details a { color: #57606a; }
    .list li div.details a:hover { color: #0969da; }
    .list li div.details * { vertical-align: middle; }
    .list li div.details .localtion { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; max-width: 150px; display: inline-block; height: 14px; }
    .list li div.details svg { width: 12px; height: 12px; margin-right: 4px; fill: #9ba1a8; display: inline-block; }

    .footer { padding: 24px 0 30px 0; font-size: 12px; color: #9ba1a8; }

    @media (max-width: 720px) {
      .title { font-size: 20px; padding-top: 36px; }
      .tabs { padding: 12px 8px 18px; }
      .tabs a { padding: 6px 10px; font-size: 13px; }
      .tab-group { margin: 0 2px; }
      .tab-group + .tab-group { margin-left: 6px; padding-left: 8px; }
      .list { margin: 0 12px; border-radius: 6px; }
      .list li { padding: 12px 14px; }
      .list li.rank-title { padding: 10px 14px; font-size: 13px; }
    }
  </style>
</head>
<body>
  <h1 class="title"> <%= title %> </h1>
  <div class="time">Last updated: <%=date%></div>
  <div class="tabs">
  <span class="tab-group">
    <a class="<%= tabCls === 'trending' ? 'active' : '' %>" href="trending.html">GitHub Trending</a>
    <a class="<%= tabCls === 'hf-trending' ? 'active' : '' %>" href="hf-trending.html">HF Trending</a>
  </span>
  <span class="tab-group">
    <a class="<%= tabCls === 'hf-papers' ? 'active' : '' %>" href="hf-papers.html">HF Papers</a>
  </span>
  <span class="tab-group">
    <a class="<%= tabCls === 'openai-news' ? 'active' : '' %>" href="openai-news.html">OpenAI</a>
    <a class="<%= tabCls === 'anthropic-news' ? 'active' : '' %>" href="anthropic-news.html">Anthropic</a>
    <a class="<%= tabCls === 'qbitai' ? 'active' : '' %>" href="qbitai.html">量子位</a>
  </span>
</div>
